<main class="relative min-h-screen bg-background text-foreground">
  <div class="grid min-h-screen lg:grid-cols-2">
    <aside class="relative hidden overflow-hidden bg-ink text-cream lg:flex lg:flex-col lg:justify-between lg:p-12">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-cream">
          <div class="h-2 w-2 rounded-full bg-coral"></div>
        </div>
        <span class="font-display text-xl font-medium">Smooth</span>
      <% end %>

      <div class="relative">
        <div class="absolute -left-8 -top-16 h-64 w-64 rounded-full bg-coral/30 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-72 w-72 rounded-full bg-sage/20 blur-3xl"></div>
        <p class="relative font-display text-4xl leading-tight tracking-tight">
          "Smooth quietly removed the part of my week I dreaded most &mdash;
          <span class="text-coral"> scheduling.</span>"
        </p>
        <p class="relative mt-6 text-sm text-cream/70">
          Mira Okafor &mdash; Independent Therapist
        </p>
      </div>

      <div class="flex items-center gap-6 text-xs uppercase tracking-[0.18em] text-cream/50">
        <span>Est. 2025</span>
        <span class="h-px w-10 bg-cream/30"></span>
        <span>Made for solo pros</span>
      </div>
    </aside>

    <section class="flex min-h-screen flex-col px-6 py-10 sm:px-10 lg:px-16">
      <div class="flex items-center justify-between lg:hidden">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-ink">
            <div class="h-2 w-2 rounded-full bg-coral"></div>
          </div>
          <span class="font-display text-xl font-medium text-ink">Smooth</span>
        <% end %>
      </div>

      <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center py-10">
        <p class="text-xs uppercase tracking-[0.18em] text-coral">Welcome back</p>
        <h1 class="mt-3 font-display text-4xl font-medium leading-[1.05] text-ink sm:text-5xl">
          Pick up where <em class="font-display italic text-coral">you left off.</em>
        </h1>
        <p class="mt-4 text-sm text-muted-foreground">
          Sign in to manage your availability, reschedules, and confirmed sessions.
        </p>

        <div class="mt-10">
          <% if notice = flash[:notice] %>
            <p class="mb-5 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700" id="notice"><%= notice %></p>
          <% end %>

          <% alert = @login_error || flash[:alert] %>

          <%= form_with url: session_url, class: "space-y-5" do |form| %>
            <label class="block">
              <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Email</span>
              <%= form.email_field :email_address,
                                   required: true,
                                   autofocus: true,
                                   autocomplete: "email",
                                   placeholder: "you@studio.com",
                                   value: params[:email_address],
                                   aria: { invalid: alert.present? },
                                   class: "w-full rounded-xl border bg-card px-4 py-3 text-sm text-ink placeholder:text-muted-foreground/60 outline-none transition #{alert.present? ? 'border-red-300 focus:border-red-400 focus:ring-2 focus:ring-red-100' : 'border-border focus:border-ink/40 focus:ring-2 focus:ring-coral/20'}" %>
            </label>

            <label class="block">
              <div class="mb-2 flex items-center justify-between">
                <span class="text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Password</span>
                <%= link_to "Forgot password?", new_password_path, class: "text-xs text-muted-foreground underline-offset-4 hover:text-ink hover:underline" %>
              </div>
              <%= form.password_field :password,
                                      required: true,
                                      autocomplete: "current-password",
                                      placeholder: "Password",
                                      maxlength: 72,
                                      aria: { invalid: alert.present?, describedby: ("session-error" if alert.present?) },
                                      class: "w-full rounded-xl border bg-card px-4 py-3 text-sm text-ink placeholder:text-muted-foreground/60 outline-none transition #{alert.present? ? 'border-red-300 focus:border-red-400 focus:ring-2 focus:ring-red-100' : 'border-border focus:border-ink/40 focus:ring-2 focus:ring-coral/20'}" %>
              <% if alert.present? %>
                <p class="mt-2 text-sm font-medium text-red-600" id="session-error"><%= alert %></p>
              <% end %>
            </label>

            <%= form.submit "Sign in", class: "w-full cursor-pointer rounded-full bg-ink px-5 py-3 text-sm font-medium text-cream transition hover:bg-ink/90" %>
          <% end %>

          <div class="my-6 flex items-center gap-4">
            <div class="h-px flex-1 bg-border"></div>
            <span class="text-xs uppercase tracking-[0.14em] text-muted-foreground">or</span>
            <div class="h-px flex-1 bg-border"></div>
          </div>

          <button type="button" class="flex w-full items-center justify-center gap-3 rounded-full border border-border bg-card px-5 py-3 text-sm font-medium text-ink transition hover:bg-muted">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"></path>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"></path>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"></path>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"></path>
            </svg>
            Continue with Google
          </button>

          <p class="mt-8 text-center text-sm text-muted-foreground">
            New to Smooth?
            <%= link_to "Create an account", new_registrations_path, class: "font-medium text-ink underline-offset-4 hover:underline" %>
          </p>
        </div>
      </div>
    </section>
  </div>
</main>
