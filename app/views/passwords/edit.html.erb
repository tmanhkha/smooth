<% content_for :title, "Choose a new Smooth password" %>
<% content_for :head do %>
  <meta name="description" content="Choose a new password for your Smooth account.">
<% end %>

<main class="relative min-h-screen bg-background text-foreground">
  <div class="grid min-h-screen lg:grid-cols-2">
    <aside class="relative hidden overflow-hidden bg-ink text-cream lg:flex lg:flex-col lg:justify-between lg:p-12">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-cream">
          <div class="h-2 w-2 rounded-full bg-coral"></div>
        </div>
        <span class="font-display text-xl font-medium">Smooth</span>
      <% end %>

      <div class="relative">
        <div class="absolute -left-8 -top-16 h-64 w-64 rounded-full bg-coral/30 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-72 w-72 rounded-full bg-sage/20 blur-3xl"></div>
        <p class="relative font-display text-4xl leading-tight tracking-tight">
          "Smooth quietly removed the part of my week I dreaded most &mdash;
          <span class="text-coral"> scheduling.</span>"
        </p>
        <p class="relative mt-6 text-sm text-cream/70">
          Mira Okafor &mdash; Independent Therapist
        </p>
      </div>

      <div class="flex items-center gap-6 text-xs uppercase tracking-[0.18em] text-cream/50">
        <span>Est. 2025</span>
        <span class="h-px w-10 bg-cream/30"></span>
        <span>Made for solo pros</span>
      </div>
    </aside>

    <section class="flex min-h-screen flex-col px-6 py-10 sm:px-10 lg:px-16">
      <div class="flex items-center justify-between lg:hidden">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-ink">
            <div class="h-2 w-2 rounded-full bg-coral"></div>
          </div>
          <span class="font-display text-xl font-medium text-ink">Smooth</span>
        <% end %>
      </div>

      <div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center py-10">
        <p class="text-xs uppercase tracking-[0.18em] text-coral">New password</p>
        <h1 class="mt-3 font-display text-4xl font-medium leading-[1.05] text-ink sm:text-5xl">
          Set a fresh <em class="font-display italic text-coral">password.</em>
        </h1>
        <p class="mt-4 text-sm text-muted-foreground">
          Choose a new password to protect your booking page and confirmed sessions.
        </p>

        <div class="mt-10">
          <% alert = @password_error || flash[:alert] %>

          <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
            <label class="block">
              <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">New password</span>
              <%= form.password_field :password,
                                      required: true,
                                      autocomplete: "new-password",
                                      placeholder: "Enter new password",
                                      maxlength: 72,
                                      aria: { invalid: alert.present? },
                                      class: "w-full rounded-xl border bg-card px-4 py-3 text-sm text-ink placeholder:text-muted-foreground/60 outline-none transition #{alert.present? ? 'border-red-300 focus:border-red-400 focus:ring-2 focus:ring-red-100' : 'border-border focus:border-ink/40 focus:ring-2 focus:ring-coral/20'}" %>
            </label>

            <label class="block">
              <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Confirm password</span>
              <%= form.password_field :password_confirmation,
                                      required: true,
                                      autocomplete: "new-password",
                                      placeholder: "Repeat new password",
                                      maxlength: 72,
                                      aria: { invalid: alert.present?, describedby: ("password-update-error" if alert.present?) },
                                      class: "w-full rounded-xl border bg-card px-4 py-3 text-sm text-ink placeholder:text-muted-foreground/60 outline-none transition #{alert.present? ? 'border-red-300 focus:border-red-400 focus:ring-2 focus:ring-red-100' : 'border-border focus:border-ink/40 focus:ring-2 focus:ring-coral/20'}" %>
              <% if alert.present? %>
                <p class="mt-2 text-sm font-medium text-red-600" id="password-update-error"><%= alert %></p>
              <% end %>
            </label>

            <%= form.submit "Save password", class: "w-full cursor-pointer rounded-full bg-ink px-5 py-3 text-sm font-medium text-cream transition hover:bg-ink/90" %>
          <% end %>

          <p class="mt-8 text-center text-sm text-muted-foreground">
            Back to
            <%= link_to "sign in", new_session_path, class: "font-medium text-ink underline-offset-4 hover:underline" %>
          </p>
        </div>
      </div>
    </section>
  </div>
</main>
