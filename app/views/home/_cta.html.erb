<section id="pricing" class="py-24 md:py-32">
  <div class="mx-auto max-w-4xl px-6 text-center">
    <p class="text-xs uppercase tracking-[0.2em] text-coral">
      Get your link
    </p>

    <h2 class="mt-4 font-display text-4xl font-medium leading-[1.05] text-ink md:text-6xl">
      Stop trading time<br />
      trading times.
    </h2>

    <p class="mx-auto mt-6 max-w-lg text-muted-foreground">
      $8/month after a 14-day trial. Cancel any time. Solo plan free forever.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <%= link_to "/book/demo",
                  class: "inline-flex items-center gap-2 rounded-full bg-ink px-7 py-3.5 text-sm font-medium text-cream transition hover:bg-ink/90" do %>
        Try a live booking →
      <% end %>

      <%= link_to "See features",
                  "#features",
                  class: "inline-flex items-center gap-2 rounded-full border border-border bg-card px-7 py-3.5 text-sm font-medium text-ink transition hover:bg-secondary" %>
    </div>
  </div>

  <footer class="mx-auto mt-24 flex max-w-6xl items-center justify-between border-t border-border px-6 pt-8 text-xs text-muted-foreground">
    <span>© 2026 Slate Scheduling</span>

    <span class="font-display italic">
      Made for people who'd rather be working.
    </span>
  </footer>
</section>
