<section class="relative overflow-hidden pb-24 pt-32 md:pb-32 md:pt-40">
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 opacity-60"
    style="
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 0%,
          color-mix(in oklab, var(--coral) 18%, transparent),
          transparent 60%
        );
    "
  ></div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <div class="animate-fade-in inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-3 py-1 text-xs text-muted-foreground backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-coral"></span>
          New — Round-robin team scheduling
        </div>

        <h1 class="animate-fade-in-up animation-delay-100 mt-6 font-display text-5xl font-medium leading-[1.02] text-ink md:text-7xl">
          Bookings <em class="not-italic text-coral">without</em><br />
          the back-and-forth.
        </h1>

        <p class="animate-fade-in animation-delay-200 mt-6 max-w-lg text-lg leading-relaxed text-muted-foreground">
          Share one link. Clients pick a time that fits both calendars.
          Confirmations, reminders, and reschedules — handled.
        </p>

        <div class="animate-fade-in-up animation-delay-300 mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/book/demo"
            class="group inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-medium text-cream transition hover:bg-ink/90"
          >
            See a live booking page

            <span class="transition group-hover:translate-x-0.5">
              →
            </span>
          </a>

          <a
            href="#how"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-card px-6 py-3 text-sm font-medium text-ink transition hover:bg-secondary"
          >
            How it works
          </a>
        </div>

        <p class="mt-6 text-xs text-muted-foreground">
          Free for individuals · No credit card · 2-minute setup
        </p>
      </div>

      <div class="animate-scale-in animation-delay-300 relative mx-auto w-full max-w-md rotate-[-1.5deg]">
        <div
          class="absolute -inset-4 -z-10 rounded-3xl opacity-70 blur-2xl"
          style="
          background:
            linear-gradient(
              135deg,
                color-mix(in oklab, var(--coral) 30%, transparent),
                color-mix(in oklab, var(--sage) 50%, transparent)
              );
          "
        ></div>

        <div class="rounded-3xl border border-border bg-card p-6 shadow-[0_30px_60px_-30px_rgba(20,20,40,0.25)]">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-xs uppercase tracking-wider text-muted-foreground">
                30 minute call
              </p>

              <p class="mt-1 font-display text-xl font-medium text-ink">
                with Maya Chen
              </p>
            </div>

            <div class="rounded-full bg-coral-soft px-2.5 py-1 text-[10px] font-medium uppercase tracking-wider text-coral">
              Live
            </div>
          </div>

          <div class="mt-5 rounded-2xl bg-secondary/60 p-4">
            <div class="flex items-center justify-between text-xs text-muted-foreground">
              <span>Thursday, May 14</span>
              <span>PST</span>
            </div>

            <div class="mt-3 grid grid-cols-3 gap-2">
              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                9:00
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                9:30
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                10:00
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                10:30
              </button>

              <button class="rounded-lg border border-ink bg-ink px-2 py-2 text-sm text-cream transition">
                11:00
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                1:00
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                1:30
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                2:00
              </button>

              <button class="rounded-lg border border-border bg-card px-2 py-2 text-sm text-ink transition hover:border-ink/40">
                2:30
              </button>
            </div>
          </div>

          <div class="mt-5 flex items-center gap-2 text-xs text-muted-foreground">
            <div class="flex -space-x-1.5">
              <div class="h-5 w-5 rounded-full border-2 border-card bg-coral"></div>
              <div class="h-5 w-5 rounded-full border-2 border-card bg-sage"></div>
            </div>

            Both calendars synced · Conflict-free
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
