<% content_for :title, "Settings - Smooth" %>

<div class="space-y-8">
  <header>
    <p class="text-xs uppercase tracking-[0.18em] text-coral">Settings</p>
    <h1 class="mt-2 font-display text-4xl font-medium text-ink">Account &amp; preferences</h1>
    <p class="mt-2 text-sm text-muted-foreground">
      Personal details, branding, and how Smooth handles bookings on your behalf.
    </p>
  </header>

  <section class="rounded-2xl border border-border bg-card p-6">
    <h2 class="font-display text-xl text-ink">Profile</h2>
    <div class="mt-5 grid gap-5 sm:grid-cols-2">
      <label class="block">
        <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Full name</span>
        <div class="flex items-center overflow-hidden rounded-xl border border-border bg-background focus-within:border-ink/40 focus-within:ring-2 focus-within:ring-coral/20">
          <input type="text" value="Mira Okafor" class="w-full bg-transparent px-4 py-3 text-sm text-ink outline-none placeholder:text-muted-foreground/60">
        </div>
      </label>

      <label class="block">
        <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Email</span>
        <div class="flex items-center overflow-hidden rounded-xl border border-border bg-background focus-within:border-ink/40 focus-within:ring-2 focus-within:ring-coral/20">
          <input type="email" value="mira@studio.com" class="w-full bg-transparent px-4 py-3 text-sm text-ink outline-none placeholder:text-muted-foreground/60">
        </div>
      </label>

      <label class="block">
        <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Booking URL</span>
        <div class="flex items-center overflow-hidden rounded-xl border border-border bg-background focus-within:border-ink/40 focus-within:ring-2 focus-within:ring-coral/20">
          <span class="border-r border-border bg-muted px-3 py-3 text-sm text-muted-foreground">smooth.to/</span>
          <input type="text" value="mira" class="w-full bg-transparent px-4 py-3 text-sm text-ink outline-none placeholder:text-muted-foreground/60">
        </div>
      </label>

      <label class="block">
        <span class="mb-2 block text-xs font-medium uppercase tracking-[0.14em] text-muted-foreground">Timezone</span>
        <div class="flex items-center overflow-hidden rounded-xl border border-border bg-background focus-within:border-ink/40 focus-within:ring-2 focus-within:ring-coral/20">
          <input type="text" value="Europe/London (GMT+1)" class="w-full bg-transparent px-4 py-3 text-sm text-ink outline-none placeholder:text-muted-foreground/60">
        </div>
      </label>
    </div>
  </section>

  <section class="rounded-2xl border border-border bg-card p-6">
    <h2 class="font-display text-xl text-ink">Automations</h2>
    <div class="mt-5 divide-y divide-border">
      <div class="flex items-start justify-between gap-4 py-4">
        <div>
          <p class="text-sm font-medium text-ink">Email reminders</p>
          <p class="mt-1 text-sm text-muted-foreground">Send a reminder 24 hours before each session.</p>
        </div>
        <button type="button" class="relative h-6 w-11 shrink-0 rounded-full bg-ink transition" aria-label="Email reminders" aria-pressed="true">
          <span class="absolute left-5 top-0.5 h-5 w-5 rounded-full bg-cream transition"></span>
        </button>
      </div>

      <div class="flex items-start justify-between gap-4 py-4">
        <div>
          <p class="text-sm font-medium text-ink">Auto-confirm new bookings</p>
          <p class="mt-1 text-sm text-muted-foreground">Skip the manual confirm step for slots you've pre-approved.</p>
        </div>
        <button type="button" class="relative h-6 w-11 shrink-0 rounded-full bg-ink transition" aria-label="Auto-confirm new bookings" aria-pressed="true">
          <span class="absolute left-5 top-0.5 h-5 w-5 rounded-full bg-cream transition"></span>
        </button>
      </div>

      <div class="flex items-start justify-between gap-4 py-4">
        <div>
          <p class="text-sm font-medium text-ink">Post-session follow-up</p>
          <p class="mt-1 text-sm text-muted-foreground">Send a thank-you note and rebook link after each session.</p>
        </div>
        <button type="button" class="relative h-6 w-11 shrink-0 rounded-full bg-muted transition" aria-label="Post-session follow-up" aria-pressed="false">
          <span class="absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-cream transition"></span>
        </button>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-destructive/30 bg-card p-6">
    <h2 class="font-display text-xl text-ink">Danger zone</h2>
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm text-muted-foreground">
        Pause your booking page or delete the account permanently.
      </p>
      <div class="flex gap-2">
        <button type="button" class="rounded-full border border-border bg-card px-4 py-2 text-sm text-ink hover:bg-muted">
          Pause page
        </button>
        <button type="button" class="rounded-full bg-destructive px-4 py-2 text-sm font-medium text-destructive-foreground hover:opacity-90">
          Delete account
        </button>
      </div>
    </div>
  </section>
</div>
