<% stats = [
  { label: "Booked this week", value: "12", trend: "+3", positive: true },
  { label: "Pending confirmations", value: "2", trend: "-1", positive: true },
  { label: "Reschedules avoided", value: "7", trend: "+2", positive: true },
  { label: "Hours saved", value: "5.4h", trend: "+0.8h", positive: true }
] %>

<% sessions = [
  { time: "10:00", name: "Aiko Tanaka", type: "Intro call - 30m", status: "Confirmed" },
  { time: "11:30", name: "Daniel Reyes", type: "Therapy - 60m", status: "Confirmed" },
  { time: "14:00", name: "Sara Lindberg", type: "Follow-up - 45m", status: "Pending" },
  { time: "16:15", name: "James O'Connor", type: "Intro call - 30m", status: "Confirmed" }
] %>

<% activity = [
  { who: "Aiko Tanaka", what: "booked Intro call", when: "12 min ago" },
  { who: "Sara Lindberg", what: "rescheduled to Thu 14:00", when: "1 h ago" },
  { who: "Reminder sent", what: "to 4 clients for tomorrow", when: "3 h ago" },
  { who: "James O'Connor", what: "confirmed via Google Cal", when: "yesterday" }
] %>

<div class="space-y-10">
  <header class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-coral">Today, May 11</p>
        <h1 class="mt-2 font-display text-4xl font-medium leading-tight text-ink">
          Welcome back, Mira.
        </h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Here's what your week looks like &mdash; calm and on-rails.
        </p>
      </div>

      <div class="flex gap-2">
        <%= link_to "Edit availability",
                    "/availability",
                    class: "rounded-full border border-border bg-card px-4 py-2.5 text-sm text-ink transition hover:bg-muted" %>
        <%= link_to "+ New session type",
                    "/bookings",
                    class: "rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-cream transition hover:bg-ink/90" %>
      </div>
  </header>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <% stats.each do |stat| %>
        <div class="rounded-2xl border border-border bg-card p-5">
          <p class="text-xs uppercase tracking-[0.14em] text-muted-foreground"><%= stat[:label] %></p>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="font-display text-3xl text-ink"><%= stat[:value] %></span>
            <span class="text-xs font-medium <%= stat[:positive] ? 'text-coral' : 'text-muted-foreground' %>">
              <%= stat[:trend] %>
            </span>
          </div>
          <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-muted">
            <div class="h-full w-3/5 rounded-full bg-ink"></div>
          </div>
        </div>
      <% end %>
  </section>

  <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6 lg:col-span-2">
        <div class="flex items-center justify-between">
          <h2 class="font-display text-xl text-ink">Today's sessions</h2>
          <%= link_to "View all",
                      "/bookings",
                      class: "text-xs uppercase tracking-[0.14em] text-coral hover:underline" %>
        </div>

        <ul class="mt-5 divide-y divide-border">
          <% sessions.each do |session| %>
            <li class="flex items-center gap-4 py-4">
              <div class="w-14 font-display text-lg text-ink"><%= session[:time] %></div>
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-coral-soft text-sm font-medium text-coral">
                <%= session[:name].split.map { |name| name[0] }.join %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="truncate text-sm font-medium text-ink"><%= session[:name] %></p>
                <p class="truncate text-xs text-muted-foreground"><%= session[:type] %></p>
              </div>
              <span class="rounded-full px-3 py-1 text-[11px] font-medium <%= session[:status] == 'Confirmed' ? 'bg-sage/30 text-ink' : 'bg-coral/15 text-coral' %>">
                <%= session[:status] %>
              </span>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="space-y-6">
        <div class="rounded-2xl border border-border bg-ink p-6 text-cream">
          <p class="text-xs uppercase tracking-[0.18em] text-coral">Your link</p>
          <p class="mt-3 font-display text-lg">smooth.to/mira</p>
          <p class="mt-2 text-sm text-cream/70">
            Share once. Smooth handles calendars, confirmations, reminders.
          </p>
          <button type="button" class="mt-5 w-full rounded-full bg-cream px-4 py-2.5 text-sm font-medium text-ink transition hover:bg-cream/90">
            Copy link
          </button>
        </div>

        <div class="rounded-2xl border border-border bg-card p-6">
          <h3 class="font-display text-lg text-ink">Recent activity</h3>
          <ul class="mt-4 space-y-4">
            <% activity.each do |item| %>
              <li class="flex gap-3 text-sm">
                <div class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-coral"></div>
                <div class="min-w-0">
                  <p class="text-ink">
                    <span class="font-medium"><%= item[:who] %></span>
                    <%= item[:what] %>
                  </p>
                  <p class="text-xs text-muted-foreground"><%= item[:when] %></p>
                </div>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
  </section>
</div>
